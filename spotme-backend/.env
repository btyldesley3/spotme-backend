# Local PostgreSQL defaults for docker-compose
POSTGRES_DB=spotme
POSTGRES_USER=spotme
POSTGRES_PASSWORD=spotme

# Keep Flyway/JPA conservative until DB migrations are added
SPRING_FLYWAY_ENABLED=false
SPRING_JPA_HIBERNATE_DDL_AUTO=none

# For future Amazon RDS, override datasource via environment at deploy time, e.g.:
# SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint:5432/spotme
# SPRING_DATASOURCE_USERNAME=*****
# SPRING_DATASOURCE_PASSWORD=*****

