{
  "version": "v1.0.0",
  "effective_date": "2025-10-17",
  "units": "kg",
  "algorithm": {
    "goal": "Keep most working sets at RPE 8–9 while steadily progressing load/reps; manage DOMS-driven recovery.",
    "order_of_operations": [
      "recovery_gate",
      "progression_logic",
      "volume_steering",
      "safety_bounds",
      "record_algorithm_run"
    ]
  },
  "globals": {
    "min_increment_by_modality": {
      "barbell_compound": 2.5,
      "barbell_upper": 1.25,
      "dumbbell": 1.25,
      "machine_compound": 2.5,
      "machine_isolation": 1.25
    },
    "weekly_volume_targets": {
      "chest": { "min": 10, "max": 16 },
      "back": { "min": 10, "max": 16 },
      "quads": { "min": 10, "max": 16 },
      "hamstrings": { "min": 8, "max": 14 },
      "glutes": { "min": 10, "max": 16 },
      "shoulders": { "min": 8, "max": 14 },
      "biceps": { "min": 6, "max": 12 },
      "triceps": { "min": 6, "max": 12 },
      "calves": { "min": 6, "max": 12 }
    },
    "rep_ranges_by_category": {
      "compound": { "low": 5, "high": 8 },
      "hypertrophy": { "low": 8, "high": 12 },
      "isolation": { "low": 10, "high": 15 }
    },
    "doms_scale": {
      "none": [0, 0],
      "mild": [1, 3],
      "moderate": [4, 6],
      "severe": [7, 10]
    },
    "max_weekly_load_increase_pct": 5.0,
    "e1rm_calc": { "method": "rpe_table", "table": "tskar_rpe_estimator_v1" }
  },
  "recovery": {
    "doms": {
      "severe_threshold": 7,
      "moderate_threshold": 4
    },
    "sleep": {
      "poor_threshold": 4
    },
    "weighting": {
      "doms_impact": 0.5,
      "rpe_influence": 0.3,
      "sleep_influence": 0.2
    },
    "safety": {
      "min_load_reduction_pct": 2.5
    }
  },
  "recovery_gate": {
    "rules": [
      {
        "when": { "doms_level": "severe" },
        "then": [
          { "action": "mirror_session" },
          { "action": "adjust_sets", "delta": -1, "min_sets": 2 },
          { "action": "swap_variant", "count": 1 }
        ],
        "stop_after": true
      },
      {
        "when": { "doms_level": "moderate", "last_top_set": { "rpe_gte": 9.5 } },
        "then": [
          { "action": "mirror_session" },
          { "action": "adjust_load_pct", "delta_pct": -2.5 }
        ],
        "stop_after": true
      },
      {
        "when": { "doms_level": "moderate" },
        "then": [
          { "action": "mirror_session" }
        ],
        "stop_after": true
      },
      {
        "when": { "doms_level_in": ["none", "mild"] },
        "then": [
          { "action": "proceed" }
        ]
      }
    ]
  },
  "progression_logic": {
    "rpe_thresholds": {
      "low": 7.0,
      "optimal_min": 8.0,
      "optimal_max": 9.0,
      "high": 9.5
    },
    "rules": [
      {
        "when": {
          "last_top_set": { "rpe_lte": 7.0, "hit_rep_target": "top_of_range" }
        },
        "then": [
          { "action": "increase_load_min_inc", "steps": 2 }
        ]
      },
      {
        "when": {
          "last_top_set": { "rpe_between": [8.0, 9.0], "hit_rep_target": "target_or_above" }
        },
        "then": [
          { "action": "increase_load_min_inc", "steps": 1 }
        ]
      },
      {
        "when": {
          "last_top_set": { "rpe_between": [8.0, 9.0], "reps_below_target_by": [1, 2] }
        },
        "then": [
          { "action": "keep_load" },
          { "action": "raise_rep_cap", "delta_reps": 1 }
        ]
      },
      {
        "when": {
          "last_top_set": { "rpe_gte": 9.5, "failed": false }
        },
        "then": [
          { "action": "adjust_load_pct", "delta_pct": -2.5 }
        ]
      },
      {
        "when": {
          "last_top_set": { "failed": true }
        },
        "then": [
          { "action": "adjust_load_pct", "delta_pct": -5.0 }
        ]
      }
    ],
    "micro_loading_policy": {
      "barbell_compound": { "min_inc": 2.5, "max_steps": 2 },
      "barbell_upper": { "min_inc": 1.25, "max_steps": 2 },
      "dumbbell": { "min_inc": 1.25, "max_steps": 2 },
      "machine_compound": { "min_inc": 2.5, "max_steps": 2 },
      "machine_isolation": { "min_inc": 1.25, "max_steps": 2 }
    }
  },
  "volume_steering": {
    "rules": [
      {
        "when": {
          "avg_rpe_lte": 8.0,
          "doms_level_in": ["none", "mild"],
          "weeks_in_state_gte": 2,
          "current_weekly_sets_pct_of_target_lte": 90
        },
        "then": [
          { "action": "adjust_backoff_sets", "delta": 1, "max_add_per_week": 2 }
        ]
      },
      {
        "when": {
          "doms_level": "severe"
        },
        "then": [
          { "action": "adjust_backoff_sets", "delta": -1 }
        ]
      }
    ]
  },
  "deload": {
    "trigger": {
      "consecutive_high_rpe_sessions": 2,
      "window_days": 14,
      "rpe_threshold": 9.5
    },
    "action": {
      "intensity_multiplier": 0.9,
      "backoff_sets_delta": -1,
      "duration_sessions": 2
    }
  },
  "scheduling": {
    "week_start": "monday",
    "map_sessions_per_week": {
      "2": "full_body_ab",
      "3": "push_pull_legs",
      "4": "upper_lower_ul",
      "5": "ppl_plus_focus"
    },
    "missed_session_policy": {
      "carry_forward_targets": true,
      "avoid_back_to_back_same_primary_muscle_if_doms_gte": 4
    },
    "extra_session_policy": {
      "type": "focus_day",
      "volume_pct": 0.6,
      "focus_selection": "lagging_muscle_lowest_volume_vs_target"
    }
  },
  "warmup": {
    "scheme": "percentage_ladder",
    "steps": [
      { "pct": 0.4, "reps": 5 },
      { "pct": 0.6, "reps": 3 },
      { "pct": 0.75, "reps": 1 }
    ]
  },
  "safety_bounds": {
    "min_working_weight_kg": 10.0,
    "max_weekly_intensity_increase_pct": 5.0,
    "rep_cap_increase_max_per_session": 1,
    "set_bounds": { "min": 2, "max": 6 }
  },
  "audit": {
    "store_algorithm_run": true,
    "include": [
      "inputs.last_session",
      "inputs.doms",
      "outputs.prescription",
      "rules_fired",
      "timestamps"
    ]
  },
  "overrides": {
    "exercise_categories": {
      "deadlift": {
        "progression_logic": {
          "rules": [
            {
              "when": {
                "last_top_set": { "rpe_between": [8.0, 9.0], "hit_rep_target": "target_or_above" }
              },
              "then": [
                { "action": "increase_load_min_inc", "steps": 1, "min_inc_override": 2.5 }
              ]
            }
          ]
        },
        "safety_bounds": {
          "max_weekly_intensity_increase_pct": 2.5
        }
      }
    }
  },
  "telemetry_events": [
    "workout_created",
    "set_logged",
    "rpe_recorded",
    "plan_applied",
    "deload_triggered",
    "rule_fired"
  ]
}
